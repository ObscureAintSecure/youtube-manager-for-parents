{
  "manifest_version": 3,
  "name": "YouTube Manager for Parents",
  "version": "2.2.1",
  "description": "Help parents manage YouTube subscriptions for their kids - bulk unsubscribe and block unwanted channels from recommendations",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
